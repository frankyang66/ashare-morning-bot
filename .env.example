# Required
FEISHU_WEBHOOK_URL=https://www.feishu.cn/flow/api/trigger-webhook/your-token

# Optional (only if your Feishu bot has signature enabled)
FEISHU_BOT_SECRET=

# LLM (OpenAI-compatible API, e.g. DeepSeek)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
STRICT_LLM=1

# RSS filtering
LOOKBACK_HOURS=24
MAX_NEWS_ITEMS=30

# Fetch tuning
RSS_FETCH_TIMEOUT=12
RSS_FETCH_WORKERS=8
TITLE_SIMILARITY_THRESHOLD=0.90
